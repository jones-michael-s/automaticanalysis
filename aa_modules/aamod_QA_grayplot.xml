<?xml version="1.0" encoding="utf-8"?>
<aap>
    <tasklist>
        <currenttask domain='session' desc='generate grayplot QA summary of epi' modality='MRI'>
            
            <permanenceofoutput>1</permanenceofoutput>
			
            <numberOfTimePointsToPlot>500</numberOfTimePointsToPlot>
			
            <!-- the mask must match the epi - if it doesn't, give the option -->
            <!-- of automatically reslicing it (time consuming if multiple -->
            <!-- calls) or bailing (user can fix the tasklist to reslice once) -->
			
           <resliceGMMaskIfNecessary>1</resliceGMMaskIfNecessary>

            <!-- tag epi as unmodifed and aa will use ln to save some disc -->
			
            <inputstreams>
               <stream ismodified='0'>epi</stream>
               <stream>native_brainmask</stream>
               <stream>tsdiffana</stream>
               <stream>realignment_parameter</stream>
            </inputstreams>
			
            <outputstreams>
               <stream>QA</stream>
            </outputstreams>
			
        </currenttask>
    </tasklist>
</aap>
